{
  "name": "webmos",
  "version": "1.0.0",
  "description": "Run MOS (Mean Opinion Score) models like DNSMOS in the browser via ONNX Runtime Web",
  "keywords": [
    "MOS",
    "mos",
    "onnx",
    "DNSMOS",
    "dnsmos",
    "audio-quality",
    "speech-quality",
    "onnxruntime",
    "browser"
  ],
  "homepage": "https://github.com/ayush-moghe/webmos#readme",
  "bugs": {
    "url": "https://github.com/ayush-moghe/webmos/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayush-moghe/webmos.git"
  },
  "license": "ISC",
  "author": "Ayush Moghe <ayush.moghe@berkeley.edu>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./models/*": "./models/*"
  },
  "files": [
    "dist",
    "models"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "onnxruntime-web": "^1.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
